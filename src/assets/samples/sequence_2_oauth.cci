  "diagramType": "sequence",
  "theme": "blue-orange",
  "bgColor": "white",
  "title": "OAuth 2.0 Authorization Code Flow",
  "data": {
    "groups": [
      {
        "id": "g_layer_0",
        "nodes": [
          {
            "id": "user",
            "text": "User App",
